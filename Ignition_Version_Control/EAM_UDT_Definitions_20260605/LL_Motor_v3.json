        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{plcName}.{device}_Motors[{motorNum}].Sts_Stopped"
      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "readOnly": false,
      "scaleMode": "Off",
      "tagType": "AtomicTag",
      "valueSource": "opc"
    },
    {
      "dataType": "Boolean",
      "name": "Sts_MotorRunning",
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{plcName}.{device}_Motors[{motorNum}].Sts_Running"
      },
      "opcServer": {
        "bindType": "parameter",
