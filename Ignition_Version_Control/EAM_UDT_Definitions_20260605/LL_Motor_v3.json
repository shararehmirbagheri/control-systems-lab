{
  "name": "LL_Motor_v3",
  "parameters": {
    "device": {
      "dataType": "Integer",
      "value": {
        "bindType": "parameter",
        "binding": "{device}"
      }
    },
    "motorNum": {
      "dataType": "Integer",
      "value": 0
    },
    "opcServer": {
      "dataType": "String",
      "value": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      }
    },
    "parent": {
      "dataType": "Integer",
      "value": {
        "bindType": "parameter",
        "binding": "{parent}"
      }
    },
    "plcName": {
      "dataType": "String",
      "value": {
        "bindType": "parameter",
        "binding": "{plcName}"
      }
    },
    "suffix": {
      "dataType": "Integer",
      "value": {
        "bindType": "parameter",
        "binding": "{suffix}"
      }
    }
  },
  "tagType": "UdtType",
  "tags": [
    {
      "alarms": [
        {
          "ackPipeline": "Alarms/Ack Alerts",
          "activePipeline": "Alarms/Critical Alerts",
          "clearPipeline": "Alarms/Critical Alerts",
          "enabled": {
            "bindType": "Expression",
            "value": "!{[.]../../TopStat/Comm_Fail}"
          },
          "label": {
            "bindType": "Expression",
            "value": "split({fullItemPath},\"/\")[4,0]+\" \"+{ParentInstanceName}+\" OoS\""
          },
          "name": "Motor OoS",
          "setpointA": 1.0
        }
      ],
      "dataType": "Int4",
      "name": "Mset_MotorOoS",
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{plcName}.{device}.MSet_MotorOoS.{motorNum}"
      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "readOnly": false,
      "scaleMode": "Off",
      "tagType": "AtomicTag",
      "valueSource": "opc"
    },
    {
      "dataType": "Boolean",
      "name": "Sts_MotorStarting",
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{plcName}.{device}_Motors[{motorNum}].Sts_Starting"
      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "readOnly": false,
      "scaleMode": "Off",
      "tagType": "AtomicTag",
      "valueSource": "opc"
    },
    {
