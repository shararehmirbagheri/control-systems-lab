      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "readOnly": false,
      "scaleMode": "Off",
      "tagType": "AtomicTag",
      "valueSource": "opc"
    },
    {
      "dataType": "Boolean",
      "name": "Sts_MotorAvail",
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{plcName}.{device}.Sts_MotorAvail.{motorNum}"
      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "readOnly": false,
      "scaleMode": "Off",
      "tagType": "AtomicTag",
      "valueSource": "opc"
    }
  ]
}