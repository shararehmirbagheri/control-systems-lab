        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "readOnly": false,
      "scaleMode": "Off",
      "tagType": "AtomicTag",
      "valueSource": "opc"
    },
    {
      "dataType": "Int4",
      "name": "MTR_Val_Rank",
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{plcName}.{device}_Motors[{motorNum}].Val_rank"
