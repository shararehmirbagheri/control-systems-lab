        },
        {
          "name": "HasUnack",
          "tagType": "AtomicTag"
        },
        {
          "name": "Priority",
          "tagType": "AtomicTag"
        },
        {
          "name": "Priorities",
          "tagType": "Folder",
          "tags": [
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027priorityCounts.\u0027 + {TagName})",
              "name": "Medium",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027priorityCounts.\u0027 + {TagName})",
              "name": "Low",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027priorityCounts.\u0027 + {TagName})",
              "name": "High",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027priorityCounts.\u0027 + {TagName})",
              "name": "Diagnostic",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027priorityCounts.\u0027 + {TagName})",
              "name": "Shelved",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027priorityCounts.\u0027 + {TagName})",
              "name": "Critical",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            }
          ]
        },
        {
          "name": "States",
          "tagType": "Folder",
          "tags": [
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027stateCounts.\u0027 + {TagName})",
              "name": "Shelved",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027stateCounts.\u0027 + {TagName})",
              "name": "ActiveUnacked",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027stateCounts.\u0027 + {TagName})",
              "name": "ActiveAcked",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027stateCounts.\u0027 + {TagName})",
              "name": "ClearUnacked",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "dataType": "Int4",
              "expression": "jsonGet({[.]../Summary}, \u0027stateCounts.\u0027 + {TagName})",
              "name": "ClearAcked",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            }
          ]
        },
        {
          "name": "Totals",
          "tagType": "Folder",
          "tags": [
            {
              "expression": "{[.]../States/ActiveUnacked}+{[.]../States/ClearUnacked}",
              "name": "Unack",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "expression": "{[.]../States/ActiveAcked}+{[.]../States/ActiveUnacked}",
              "name": "Active",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            },
            {
              "expression": "{[.]../States/ActiveAcked}+{[.]../States/ActiveUnacked}+{[.]../States/ClearUnacked}",
              "name": "ActiveOrUnack",
              "readOnly": true,
              "tagType": "AtomicTag",
              "valueSource": "expr"
            }
          ]
        },
        {
          "name": "Summary",
          "tagType": "AtomicTag"
        }
      ],
      "typeId": "Admin/Alarm_Summary"
    },
    {
      "dataType": "DateTime",
      "formatString": "yyyy-MM-dd h:mm:ss aa",
      "name": "version",
      "tagType": "AtomicTag",
      "value": 1779807143058,
      "valueSource": "memory"
    },
