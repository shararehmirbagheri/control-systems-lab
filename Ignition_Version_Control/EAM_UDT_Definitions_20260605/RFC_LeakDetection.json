          "tagType": "AtomicTag"
        },
        {
          "name": "MaintenanceMode Changed",
          "tagType": "AtomicTag"
        },
        {
          "name": "Note",
          "tagType": "AtomicTag"
        }
      ],
      "typeId": "Admin/Maintenance"
    },
    {
      "name": "Alarm_Summary",
