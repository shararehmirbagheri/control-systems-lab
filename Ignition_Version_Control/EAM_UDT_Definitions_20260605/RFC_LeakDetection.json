    "location": {
      "dataType": "Integer"
    },
    "room": {
      "dataType": "Integer"
    },
    "site": {
      "dataType": "String",
      "value": ""
    }
  },
  "tagType": "UdtType",
  "tags": [
    {
      "name": "Maintenance",
