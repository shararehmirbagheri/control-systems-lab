            "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{device}.{MBReg_AlmFlwSw}@Boolean"
          },
          "opcServer": {
            "bindType": "parameter",
            "binding": "{opcServer}"
          },
          "readOnly": true,
          "tagType": "AtomicTag",
          "valueSource": "opc"
        },
        {
          "alarms": [
            {
              "CustomEmailMessage": {
                "bindType": "Expression",
                "value": "\"\u003chtml\u003eTime: \"+toStr({Timestamp})+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eLineup: \"+split({fullItemPath},\"/\")[1,0]+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eDevice: \"+{InstanceName}+\"\u003cbr\u003e\"+\r\n\"Alarm: \"+{name}+\"\u003cbr\u003e\"+\r\n\"Has changed to : \" + toSTR({State})+\"\u003cbr\u003e\""
              },
              "CustomEmailSubject": {
                "bindType": "Expression",
                "value": "\"Alarm - \"+\r\n{name}+\r\n\" \"+\r\n{state}+\r\n\" on \" +\r\n{InstanceName}"
              },
              "ackPipeline": "Alarms/Ack Alerts",
              "activePipeline": "Alarms/Critical Alerts",
              "clearPipeline": "Alarms/Critical Alerts",
              "enabled": {
                "bindType": "Expression",
                "value": "!(tag(\"[.]Rollup_\"+{TageName}+\"/Rollup Changed\")||{[.]../Maintenance/MaintenanceMode Changed})\u0026\u0026!{[.]../TopStat/Comm_Fail}"
              },
              "externalNotify": "True",
              "label": {
                "bindType": "Expression",
                "value": "{InstanceName}+\" \"+{name}"
              },
              "name": "{TagName}",
              "priority": {
                "bindType": "Expression",
                "value": "if(tag(\"[.]Rollup_\"+{TagName}+\"/Rollup Active\")||{[.]../Maintenance/MaintenanceMode},\"Low\",\"High\")"
              },
              "setpointA": 1.0
            }
          ],
          "dataType": "Boolean",
          "name": "Alm_SupplyValve",
          "opcItemPath": {
            "bindType": "parameter",
            "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{device}.{MBReg_AlmSplyVlv}@Boolean"
          },
          "opcServer": {
            "bindType": "parameter",
            "binding": "{opcServer}"
          },
          "readOnly": true,
          "tagType": "AtomicTag",
          "valueSource": "opc"
        }
      ]
    },
