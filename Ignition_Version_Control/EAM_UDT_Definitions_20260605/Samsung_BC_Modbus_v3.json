              "script": "\tdef updateRackEnable(startRack, endRack, doEnable):\n\t\tfor x in range(startRack, endRack):\n\t\t\tbase_path\u003d\u0027/\u0027.join(tagPath.split(\u0027/\u0027)[:-2])\n\t\t\tbase_list\u003d[\n\t\t\tbase_path + \"/data/Rack\" + str(x) + \"_CB_State.Enabled\",\n\t\t\tbase_path + \"/data/Rack\" + str(x) + \"_Current.Enabled\",\n\t\t\tbase_path + \"/data/Rack\" + str(x) + \"_Voltage.Enabled\"\n\t\t\t]\n\t\t\tresponse\u003dsystem.tag.writeAsync(base_list,[doEnable]*len(base_list))\n\t\t\t\n\tif initialChange:\n\t\t updateRackEnable(1,currentValue.value+1,True)\t\n\t\t \n\telif previousValue.value \u003c currentValue.value:\n\t\t updateRackEnable(previousValue.value,currentValue.value+1,True)\t\n\t\t \n\telif initialChange or previousValue.value \u003e currentValue.value:\n\t\t updateRackEnable(currentValue.value+1,previousValue.value+1,False)\t"
            }
