{
  "name": "Suite_Summary",
  "parameters": {
    "Has_Cooling": {
      "dataType": "String",
      "value": ""
    },
    "Has_Electrical": {
      "dataType": "String",
      "value": ""
    }
  },
  "tagType": "UdtType",
  "tags": [
    {
      "dataType": "Float4",
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Cooling}"
      },
      "engUnit": "%",
      "executionMode": "TagGroupRate",
      "executionRate": 1000,
      "expression": "runScript(\"shared.summarys.suiteRelHum\",1000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "historicalDeadband": 0.1,
      "historyEnabled": true,
      "historyMaxAge": 1,
      "historyProvider": "cnpg",
      "name": "Rel_Humidity",
      "sampleMode": "TagGroup",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Float4",
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Cooling}"
      },
      "executionMode": "TagGroupRate",
      "executionRate": 1000,
      "expression": "runScript(\"shared.summarys.suiteActiveChillers\",1000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "historicalDeadband": 0.1,
      "historyEnabled": true,
      "historyMaxAge": 1,
      "historyProvider": "cnpg",
      "name": "Active_Chillers",
      "sampleMode": "TagGroup",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Float4",
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Cooling}"
      },
      "engUnit": "°F",
      "executionMode": "TagGroupRate",
      "executionRate": 1000,
      "expression": "runScript(\"shared.summarys.suiteAvgTemp_Secondary\",1000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "historicalDeadband": 0.1,
      "historyEnabled": true,
      "historyMaxAge": 1,
      "historyProvider": "cnpg",
      "name": "Avg_Temp_Secondary",
      "sampleMode": "TagGroup",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Cooling}"
      },
      "expression": "runScript(\"shared.summarys.suiteChillers\",10000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "name": "Chiller_Count",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "String",
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Electrical}"
      },
      "engUnit": "kW",
      "executionMode": "TagGroupRate",
      "executionRate": 1000,
      "expression": "runScript(\"shared.summarys.suiteTotalLoad\",1000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "historicalDeadband": 1.0,
      "historyEnabled": true,
      "historyMaxAge": 1,
      "historyProvider": "cnpg",
      "name": "Total_Load",
      "sampleMode": "TagGroup",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Float4",
      "documentation": "To only be enabled at sites that require the display of Supply Air Average Temp from CRAC-CRAHs for SLA purposes.",
      "enabled": false,
      "engUnit": "°F",
      "executionMode": "TagGroupRate",
      "executionRate": 1000,
      "expression": "runScript(\"shared.summarys.suiteAvgTemp_AirSupply\",10000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "historicalDeadband": 0.1,
      "historyEnabled": true,
      "historyMaxAge": 1,
      "historyProvider": "cnpg",
      "name": "Avg_Temp_AirSupply",
      "sampleMode": "TagGroup",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Boolean",
      "enabled": true,
      "eventScripts": [
        {
          "eventid": "valueChanged",
          "script": "#\tif not initialChange:\n\t\tif currentValue.value:\n\t\t\tsystem.tag.writeAsync([\"[.]./Parameters.Has_Electrical\"],[True])\n\t\telse:\n\t\t\tsystem.tag.writeAsync([\"[.]./Parameters.Has_Electrical\"],[False])"
        }
      ],
      "executionMode": "FixedRate",
      "executionRate": 5000,
      "expression": "if({Has_Electrical}\u003d\"\",false,try({[.]../Electrical}\u003e0,false))",
      "name": "Has_Electrical",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Float4",
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Electrical}"
      },
      "engUnit": "kW",
      "executionMode": "TagGroupRate",
      "executionRate": 1000,
      "expression": "runScript(\"shared.summarys.suiteItLoad\",1000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "historicalDeadband": 1.0,
      "historyEnabled": true,
      "historyMaxAge": 1,
      "historyProvider": "cnpg",
      "name": "IT_Load",
      "sampleMode": "TagGroup",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Float4",
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Cooling}"
      },
      "engUnit": "°F",
      "executionMode": "TagGroupRate",
      "executionRate": 1000,
      "expression": "runScript(\"shared.summarys.suiteAvgTemp\",1000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "historicalDeadband": 0.1,
      "historyEnabled": true,
      "historyMaxAge": 1,
      "historyProvider": "cnpg",
      "name": "Avg_Temp",
      "sampleMode": "TagGroup",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Boolean",
      "enabled": true,
      "eventScripts": [
        {
          "eventid": "valueChanged",
          "script": "#\tif not initialChange:\n\t\tif currentValue.value:\n\t\t\tsystem.tag.writeAsync([\"[.]./Parameters.Has_Cooling\"],[True])\t\n\t\telse:\n\t\t\tsystem.tag.writeAsync([\"[.]./Parameters.Has_Cooling\"],[False])"
        }
      ],
      "executionMode": "FixedRate",
      "executionRate": 5000,
      "expression": "if({Has_Cooling}\u003d\"\",false,try({[.]../Cooling}\u003e0,false))",
      "name": "Has_Cooling",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Float4",
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Cooling}"
      },
      "engUnit": "GPM",
      "executionMode": "TagGroupRate",
      "executionRate": 1000,
      "expression": "runScript(\"shared.summarys.suiteFlowTotal\",10000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "historicalDeadband": 0.1,
      "historyEnabled": true,
      "historyMaxAge": 1,
      "historyProvider": "cnpg",
      "name": "Flow_Total",
      "sampleMode": "TagGroup",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Float4",
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Cooling}"
      },
      "engUnit": "Tons",
      "expression": "runScript(\"shared.summarys.suiteTotalTons\",10000,replace({PathToParentFolder},\"/Suite_Summary\",\"\"))",
      "name": "Total_Tonnage",
      "tagGroup": "Expression10",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "String",
      "expression": "runScript(\"shared.summarys.getLocation\")",
      "name": "Location",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    },
    {
      "dataType": "Float4",
      "enabled": {
        "bindType": "parameter",
        "binding": "{Has_Electrical}"
      },
      "expression": "{[.]Total_Load}/{[.]IT_Load}",
      "historyEnabled": true,
      "historyMaxAge": 1,
      "historyProvider": "cnpg",
      "name": "PUE",
      "sampleMode": "TagGroup",
      "tagType": "AtomicTag",
      "valueSource": "expr"
    }
  ]
}