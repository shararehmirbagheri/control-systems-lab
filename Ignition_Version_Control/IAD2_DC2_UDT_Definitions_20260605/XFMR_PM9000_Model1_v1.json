              "CustomEmailSubject": {
                "bindType": "Expression",
                "value": "\"Alarm - \"+\r\n{name}+\r\n\" \"+\r\n{state}+\r\n\" on \" +\r\n{InstanceName}"
              },
              "label": {
                "bindType": "Expression",
                "value": "{InstanceName}+\" \"+{name}"
              },
              "priority": {
                "bindType": "Expression",
                "value": "if({[.]RollUp/XFMR_Trip_Alarm/Rollup Active}||{[.]../Maintenance/MaintenanceMode},\"Low\",\"High\")"
              },
              "enabled": {
                "bindType": "Expression",
                "value": "!({[.]RollUp/XFMR_Trip_Alarm/Rollup Changed}||{[.]../Maintenance/MaintenanceMode Changed})\u0026\u0026!{[.]../TopStat/Comm_Fail}"
