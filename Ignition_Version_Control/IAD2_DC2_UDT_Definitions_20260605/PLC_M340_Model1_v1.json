            "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{device}.400252.1@Boolean"
          },
          "opcServer": {
            "bindType": "parameter",
            "binding": "{opcserver}"
          },
          "valueSource": "opc",
          "expression": "if({[.]../Data/System_On_Utility}\u003d1,1,0)",
          "dataType": "Boolean",
          "alarms": [
            {
              "mode": "Equality",
              "setpointA": 1.0,
              "activePipeline": "Alarms/Critical Alerts",
              "timeOnDelaySeconds": 10.0,
              "name": "Utility_Breaker_FTO",
              "clearPipeline": "Alarms/Critical Alerts",
              "deadbandMode": "Absolute",
              "externalNotify": "True",
              "CustomEmailMessage": {
                "bindType": "Expression",
                "value": "\"\u003chtml\u003eTime: \"+toStr({Timestamp})+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eLineup: \"+split({fullItemPath},\"/\")[1,0]+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eDevice: \"+{InstanceName}+\"\u003cbr\u003e\"+\r\n\"Alarm: \"+{name}+\"\u003cbr\u003e\"+\r\n\"Has changed to : \" + toSTR({State})+\"\u003cbr\u003e\""
              },
              "CustomEmailSubject": {
                "bindType": "Expression",
                "value": "\"Alarm - \"+\r\n{name}+\r\n\" \"+\r\n{state}+\r\n\" on \" +\r\n{InstanceName}"
              },
              "label": {
                "bindType": "Expression",
                "value": "{device}+\" \"+{name}"
              },
              "priority": {
                "bindType": "Expression",
                "value": "if({[.]RollUp/Utility_Breaker_FTO/Rollup Active}||{[.]../Maintenance/MaintenanceMode},\"Low\",\"High\")"
              },
              "enabled": {
                "bindType": "Expression",
                "value": "!({[.]RollUp/Utility_Breaker_FTO/Rollup Changed}||{[.]../Maintenance/MaintenanceMode Changed})\u0026\u0026!{[.]../TopStat/Comm_Fail}"
              }
            }
          ],
          "name": "Utility_Breaker_FTO",
          "enabled": false,
          "tagType": "AtomicTag"
        }
      ]
    }
  ]
}