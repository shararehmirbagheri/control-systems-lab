              "setpointA": 0.0,
              "activePipeline": "Alarms/Critical Alerts",
              "name": "Comm_Error",
              "clearPipeline": "Alarms/Critical Alerts",
              "label": "{InstanceName}+\" \"+{name}",
              "externalNotify": "True",
              "CustomEmailMessage": {
                "bindType": "Expression",
                "value": "\"\u003chtml\u003eTime: \"+toStr({Timestamp})+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eLineup: \"+split({fullItemPath},\"/\")[1,0]+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eDevice: \"+{InstanceName}+\"\u003cbr\u003e\"+\r\n\"Alarm: \"+{name}+\"\u003cbr\u003e\"+\r\n\"Has changed to : \" + toSTR({State})+\"\u003cbr\u003e\""
              },
              "CustomEmailSubject": {
                "bindType": "Expression",
                "value": "\"Alarm - \"+\r\n{name}+\r\n\" \"+\r\n{state}+\r\n\" on \" +\r\n{InstanceName}"
              },
              "priority": {
                "bindType": "Expression",
                "value": "if({[.]RollUp/Comm_Error/Rollup Active}||{[.]../Maintenance/MaintenanceMode},\"Low\",\"Medium\")"
              },
              "enabled": {
                "bindType": "Expression",
                "value": "!({[.]RollUp/Comm_Error/Rollup Changed}||{[.]../Maintenance/MaintenanceMode Changed})\u0026\u0026!{[.]../TopStat/Comm_Fail}"
              }
            }
