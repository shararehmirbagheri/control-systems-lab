{
  "name": "CAHU_Model1_v1",
  "typeId": "",
  "parameters": {
    "parent": {
      "dataType": "String"
    },
    "datahall": {
      "dataType": "String"
    },
    "location": {
      "dataType": "String",
      "value": ""
    },
    "suffix": {
      "dataType": "String",
      "value": "CH"
    },
    "floor": {
      "dataType": "String",
      "value": ""
    },
    "device": {
      "dataType": "String",
      "value": ""
    },
    "room": {
      "dataType": "String",
      "value": ""
    },
    "opcServer": {
      "dataType": "String"
    }
  },
  "tagType": "UdtType",
  "tags": [
    {
      "name": "Alarms",
      "tagType": "Folder",
      "tags": [
        {
          "name": "Bad_Data",
          "typeId": "Admin/Bad_Data",
          "tagType": "UdtInstance",
          "tags": [
            {
              "name": "OPC_Data_Bad",
              "tagType": "AtomicTag"
            }
          ]
        },
        {
          "opcItemPath": {
            "bindType": "parameter",
            "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{device}.10169"
          },
          "opcServer": {
            "bindType": "parameter",
            "binding": "{opcServer}"
          },
          "valueSource": "expr",
          "historyMaxAge": 900000,
          "expression": "if({[.]../data/System_On_Status}, 0, 1)",
          "historicalDeadband": 1.0,
          "alarms": [
            {
              "setpointA": 1.0,
              "activePipeline": "Alarms/Critical Alerts",
              "name": "Data_Quality",
              "clearPipeline": "Alarms/Critical Alerts",
              "externalNotify": "True",
              "CustomEmailMessage": {
                "bindType": "Expression",
                "value": "\"\u003chtml\u003eTime: \"+toStr({Timestamp})+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eLineup: \"+split({fullItemPath},\"/\")[1,0]+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eDevice: \"+{InstanceName}+\"\u003cbr\u003e\"+\r\n\"Alarm: \"+{name}+\"\u003cbr\u003e\"+\r\n\"Has changed to : \" + toSTR({State})+\"\u003cbr\u003e\""
              },
              "CustomEmailSubject": {
                "bindType": "Expression",
                "value": "\"Alarm - \"+\r\n{name}+\r\n\" \"+\r\n{state}+\r\n\" on \" +\r\n{InstanceName}"
              },
              "label": {
                "bindType": "Expression",
                "value": "{InstanceName}+\" \"+{name}"
              },
              "priority": {
                "bindType": "Expression",
                "value": "if({[.]RollUp/Data_Quality/Rollup Active}||{[.]../Maintenance/MaintenanceMode},\"Low\",\"Low\")"
              },
              "enabled": {
                "bindType": "Expression",
                "value": "!({[.]RollUp/Data_Quality/Rollup Changed}||{[.]../Maintenance/MaintenanceMode Changed})\u0026\u0026!{[.]../TopStat/Comm_Fail}"
              }
            }
          ],
          "enabled": true,
          "tagType": "AtomicTag",
          "scaleMode": "Off",
          "readOnly": true,
          "dataType": "Boolean",
          "historyProvider": "cnpg",
          "historyMaxAgeUnits": "MS",
          "name": "Data_Quality_Bad",
          "historyEnabled": true,
          "sampleMode": "TagGroup"
        },
        {
          "name": "Rollup",
          "tagType": "Folder"
        }
      ]
    },
    {
      "name": "data",
      "tagType": "Folder",
