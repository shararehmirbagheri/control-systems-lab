{
  "name": "TopStat_v2",
  "typeId": "",
  "parameters": {
    "opcPathDevice": {
      "dataType": "String"
    },
    "device": {
      "dataType": "String",
      "value": {
        "bindType": "parameter",
        "binding": "{device}"
      }
    },
    "opcPath": {
      "dataType": "String",
      "value": {
        "bindType": "parameter",
        "binding": "{opcPath}"
      }
    },
    "opcServer": {
      "dataType": "String",
      "value": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      }
    }
  },
  "tagType": "UdtType",
  "tags": [
    {
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{opcPathDevice}._System._Error"
      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "valueSource": "opc",
      "dataType": "Boolean",
      "alarms": [
        {
          "setpointA": 1.0,
          "timeOnDelaySeconds": 60.0,
          "name": "Comm_Fail",
          "timeOffDelaySeconds": 300.0,
          "externalNotify": "True",
          "displayPath": {
            "bindType": "Expression",
            "value": "{device}+\" \"+{name}"
          },
          "priority": {
            "bindType": "Expression",
            "value": "if({[.]../Data/RollUp_Comm_Fail/Rollup Changed}||{[.]../Maintenance/MaintenanceMode},\"Low\",\"High\")"
          },
          "enabled": {
            "bindType": "Expression",
            "value": "!({[.]../Data/RollUp_Comm_Fail/Rollup Changed}||{[.]../Maintenance/MaintenanceMode Changed})"
          }
        }
      ],
      "name": "Comm_Fail",
      "tagType": "AtomicTag"
    },
    {
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{opcPathDevice}._System._Enabled"
      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "valueSource": "opc",
      "dataType": "Boolean",
      "name": "Enabled",
      "tagType": "AtomicTag"
    },
    {
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{opcPathDevice}._Statistics._FailedReads"
      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "valueSource": "opc",
      "dataType": "Float4",
      "name": "Failed Reads",
      "tagType": "AtomicTag"
    },
    {
      "valueSource": "expr",
      "eventScripts": [
        {
          "eventid": "valueChanged",
          "script": "\tbase_path \u003d \u0027/\u0027.join(tagPath.split(\u0027/\u0027)[:-1])\n\tsystem.tag.writeBlocking([base_path + \u0027/Parameters.opcPathDevice\u0027], [currentValue])"
        }
      ],
      "expression": "subString({opcPath}, 0, lastIndexOf({opcPath}, \".\"))",
      "dataType": "String",
      "name": "opcPathDevice",
      "tagType": "AtomicTag"
    },
    {
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{opcPathDevice}._Statistics._SuccessfulReads"
      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "valueSource": "opc",
      "dataType": "Float4",
      "name": "Successful Reads",
      "tagType": "AtomicTag"
    },
    {
      "opcItemPath": {
        "bindType": "parameter",
        "binding": "nsu\u003dTOP Server;s\u003d{opcPathDevice}._System._DeviceId"
      },
      "opcServer": {
        "bindType": "parameter",
        "binding": "{opcServer}"
      },
      "valueSource": "opc",
      "dataType": "String",
      "name": "Hostname",
      "tagType": "AtomicTag"
    }
  ]
}