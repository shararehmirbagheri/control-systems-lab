          "tagType": "AtomicTag"
        },
        {
          "opcItemPath": {
            "bindType": "parameter",
            "binding": "nsu\u003dTOP Server;s\u003d{device}.{plcName}_{mvgName}_{way_tripped}@Boolean"
          },
          "opcServer": {
            "bindType": "parameter",
            "binding": "{opcServer}"
          },
          "valueSource": "opc",
          "dataType": "Boolean",
