            {
              "mode": "Equality",
              "setpointA": 1.0,
              "ackPipeline": "Alarms/Ack Alerts",
              "activePipeline": "Alarms/Critical Alerts",
              "timeOnDelaySeconds": 10.0,
              "name": "Way1_Tripped",
              "clearPipeline": "Alarms/Critical Alerts",
              "externalNotify": "True",
              "CustomEmailMessage": {
                "bindType": "Expression",
                "value": "\"\u003chtml\u003eTime: \"+toStr({Timestamp})+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eLineup: \"+split({fullItemPath},\"/\")[1,0]+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eDevice: \"+{InstanceName}+\"\u003cbr\u003e\"+\r\n\"Alarm: \"+{name}+\"\u003cbr\u003e\"+\r\n\"Has changed to : \" + toSTR({State})+\"\u003cbr\u003e\""
              },
              "CustomEmailSubject": {
                "bindType": "Expression",
                "value": "\"Alarm - \"+\r\n{name}+\r\n\" \"+\r\n{state}+\r\n\" on \" +\r\n{InstanceName}"
              },
              "label": {
                "bindType": "Expression",
                "value": "{device}+\" \"+{name}"
              },
              "priority": {
                "bindType": "Expression",
                "value": "if({[.]Rollup_Way_Tripped/Rollup Active}||{[.]../Maintenance/MaintenanceMode},\"Low\",\"Critical\")"
              },
              "enabled": {
                "bindType": "Expression",
                "value": "!({[.]Rollup_Way_Tripped/Rollup Changed}||{[.]../Maintenance/MaintenanceMode Changed})\u0026\u0026!{[.]../TopStat/Comm_Fail}"
              }
            }
          ],
          "name": "Way_Tripped",
          "tagType": "AtomicTag"
        },
        {
          "valueSource": "expr",
