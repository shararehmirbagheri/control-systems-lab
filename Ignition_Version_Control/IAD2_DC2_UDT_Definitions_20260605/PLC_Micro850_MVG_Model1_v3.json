          "valueSource": "expr",
          "expression": "IF(isGood({[.]Way_Closed}) \u0026\u0026 isGood({[.]Way_Open}),\r\nIF({[.]Way_Closed}\u003d0 \u0026\u0026 {[.]Way_Open}\u003d1,1,\r\nIF({[.]Way_Closed}\u003d1 \u0026\u0026 {[.]Way_Open}\u003d0,2,\r\n0)),0)",
