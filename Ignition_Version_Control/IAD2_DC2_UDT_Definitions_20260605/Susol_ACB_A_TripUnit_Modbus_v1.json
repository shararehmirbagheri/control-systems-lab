        {
          "valueSource": "expr",
          "expression": "{[.]CB_Position}+1",
          "name": "Pos",
          "enabled": false,
          "tagType": "AtomicTag"
        },
        {
          "valueSource": "expr",
          "expression": "\"Breaker Position is \"+case({[.]Pos},\r\n0,\"Unknown\",\r\n1,\"Open\",\r\n2,\"Closed\",\r\n3,\"Invalid\",\r\n\"Invalid\")\r\n+\" and Rack Position is \"+case({[.]RackPos},\r\n0,\"Unknown\",\r\n1,\"Racked Out\",\r\n2,\"Racked In\",\r\n3,\"Invalid\",\r\n\"Invalid\")",
          "dataType": "String",
          "name": "Status",
          "enabled": false,
          "tagType": "AtomicTag"
        },
        {
          "opcItemPath": {
            "bindType": "parameter",
            "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{device}.30009@word"
