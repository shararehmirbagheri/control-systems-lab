          },
          "valueSource": "opc",
          "historyMaxAge": 15,
          "historicalDeadband": 0.0,
          "alarms": [
            {
              "setpointA": 1.0,
              "mode": "AboveValue",
              "anyChange": false,
              "activePipeline": "Alarms/Critical Alerts",
              "name": "Boiler_Alarm",
              "clearPipeline": "Alarms/Critical Alerts",
              "CustomEmailMessage": {
                "bindType": "Expression",
                "value": "\"\u003chtml\u003eTime: \"+toStr({Timestamp})+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eLineup: \"+split({fullItemPath},\"/\")[1,0]+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eDevice: \"+{InstanceName}+\"\u003cbr\u003e\"+\r\n\"Alarm: \"+{name}+\"\u003cbr\u003e\"+\r\n\"Has changed to : \" + toSTR({State})+\"\u003cbr\u003e\""
              },
              "CustomEmailSubject": {
                "bindType": "Expression",
                "value": "\"Alarm - \"+\r\n{name}+\r\n\" \"+\r\n{state}+\r\n\" on \" +\r\n{InstanceName}"
              },
              "label": {
                "bindType": "Expression",
                "value": "{InstanceName}+\" \"+case({[.]Boiler_Alarm},\r\n1,\"Failed Pump\",\r\n2,\"Fill Timeout\",\r\n3,\"Blocked Piping\",\r\n4,\"Heat Timeout\",\r\n5,\"Overheat\",\r\n6,\"Water Leak\",\r\n7,\"Service\",\r\n9,\"Tank Blocked\",\r\n10,\"Refill Delay\",\r\n\"Boiler Alarm\")"
              },
              "priority": {
                "bindType": "Expression",
                "value": "if({[.]RollUp/Boiler_Alarm/Rollup Active}||{[.]../Maintenance/MaintenanceMode},\"Low\",\"High\")"
              },
              "enabled": {
                "bindType": "Expression",
                "value": "!({[.]RollUp/Boiler_Alarm/Rollup Changed}||{[.]../Maintenance/MaintenanceMode Changed})"
              }
            }
          ],
          "documentation": "0 \u003d Normal\n1 \u003d FailedPump\n2 \u003d FillTimeout\n3 \u003d BlockedPiping\n4 \u003d HeatTimeout\n5 \u003d Overheat\n6 \u003d WaterLeak\n7 \u003d Service\n8 is Reserved\n9 \u003d TankBlocked\n10 \u003d RefillDelay",
          "tagType": "AtomicTag",
          "dataType": "Int4",
          "historyProvider": "cnpg",
          "historyMaxAgeUnits": "MIN",
          "name": "Boiler_Alarm",
          "historyEnabled": false,
