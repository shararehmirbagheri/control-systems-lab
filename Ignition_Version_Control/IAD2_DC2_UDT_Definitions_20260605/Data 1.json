    {
      "valueSource": "expr",
      "eventScripts": [
        {
          "eventid": "valueChanged",
          "script": "\tdef updateEnable(startMotor, endMotor, doEanble):\n\t\tif startMotor \u003c 10 and endMotor \u003c 10:\n\t\t\tfor x in range(startMotor+1, endMotor+1):\n\t\t\t\tbase_path\u003d\u0027/\u0027.join(tagPath.split(\u0027/\u0027)[:-1])\n\t\t\t\tbase_list\u003d[\n\t\t\t\tbase_path + \"/Motor_0\" + str(x) + \".Enabled\"\n\t\t\t\t]\n\t\t\t\tsystem.tag.writeAsync(base_list,[doEanble])\n\t\telif startMotor \u003c 10 and endMotor \u003e\u003d 10:\n\t\t\tfor x in range(startMotor+1, 10):\n\t\t\t\tbase_path\u003d\u0027/\u0027.join(tagPath.split(\u0027/\u0027)[:-1])\n\t\t\t\tbase_list\u003d[\n\t\t\t\tbase_path + \"/Motor_0\" + str(x) + \".Enabled\"\n\t\t\t\t]\n\t\t\t\tsystem.tag.writeAsync(base_list,[doEanble])\n\t\t\tfor x in range(10, endMotor+1):\n\t\t\t\tbase_path\u003d\u0027/\u0027.join(tagPath.split(\u0027/\u0027)[:-1])\n\t\t\t\tbase_list\u003d[\n\t\t\t\tbase_path + \"/Motor_\" + str(x) + \".Enabled\"\n\t\t\t\t]\n\t\t\t\tsystem.tag.writeAsync(base_list,[doEanble])\n\t\telse:\n\t\t\tfor x in range(startMotor+1, endMotor+1):\n\t\t\t\tbase_path\u003d\u0027/\u0027.join(tagPath.split(\u0027/\u0027)[:-1])\n\t\t\t\tbase_list\u003d[\n\t\t\t\tbase_path + \"/Motor_\" + str(x) + \".Enabled\"\n\t\t\t\t]\n\t\t\t\tsystem.tag.writeAsync(base_list,[doEanble])\n\t\t\t\t\n\tif initialChange:\n\t\tupdateEnable(0,currentValue.value,True)\n\telif previousValue.value \u003c currentValue.value:\n\t\tupdateEnable(previousValue.value,currentValue.value,True)\n\telif initialChange or previousValue.value \u003e currentValue.value:\n\t\tupdateEnable(currentValue.value,previousValue.value, False)"
        }
      ],
      "expression": "len(split({motors},\",\"))",
      "name": "motor_count",
      "executionMode": "EventDriven",
      "executionRate": 1,
      "tagType": "AtomicTag"
    },
