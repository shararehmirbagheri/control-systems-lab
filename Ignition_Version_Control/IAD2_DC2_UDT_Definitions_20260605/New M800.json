            "bindType": "parameter",
            "binding": "{opcServer}"
          },
          "valueSource": "opc",
          "dataType": "Boolean",
          "name": "Fault",
          "enabled": true,
          "tagType": "AtomicTag"
        },
        {
          "opcItemPath": {
            "bindType": "parameter",
            "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{parent}.DateTime_Current.Sec"
          },
          "opcServer": {
            "bindType": "parameter",
            "binding": "{opcServer}"
          },
          "valueSource": "expr",
          "historyMaxAge": 1,
          "expression": "secondsBetween({[.]HB.timestamp},now())",
          "historicalDeadband": 1.0,
          "alarms": [
            {
              "mode": "AboveValue",
              "setpointA": 90.0,
              "ackPipeline": "Alarms/Ack Alerts",
              "activePipeline": "",
              "setpointB": 4.0,
              "name": "HB_alarm",
              "clearPipeline": "",
              "externalNotify": "True",
              "CustomEmailMessage": {
                "bindType": "Expression",
                "value": "\"\u003chtml\u003eTime: \"+toStr({Timestamp})+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eLineup: \"+split({fullItemPath},\"/\")[1,0]+\"\u003cbr\u003e\"+\r\n\"\u003chtml\u003eDevice: \"+{InstanceName}+\"\u003cbr\u003e\"+\r\n\"Alarm: \"+{name}+\"\u003cbr\u003e\"+\r\n\"Has changed to : \" + toSTR({State})+\"\u003cbr\u003e\""
              },
              "CustomEmailSubject": {
                "bindType": "Expression",
                "value": "\"Alarm - \"+\r\n{name}+\r\n\" \"+\r\n{state}+\r\n\" on \" +\r\n{InstanceName}"
              },
              "label": {
                "bindType": "Expression",
                "value": "{InstanceName}+\" \"+{name}"
              },
              "priority": {
                "bindType": "Expression",
                "value": "if({[.]Rollup_HB_alarm/Rollup Active}||{[.]../Maintenance/MaintenanceMode},\"High\",\"Low\")"
              },
              "enabled": {
                "bindType": "Expression",
                "value": "!({[.]Rollup_HB_alarm/Rollup Changed}||{[.]../Maintenance/MaintenanceMode Changed})\u0026\u0026!{[.]../TopStat/Error}"
              }
            }
          ],
          "enabled": true,
          "tagType": "AtomicTag",
          "readOnly": true,
          "dataType": "Int4",
          "historyProvider": "cnpg",
          "historyMaxAgeUnits": "DAY",
          "name": "HB_alarm",
          "historyEnabled": false,
          "sampleMode": "TagGroup"
        }
