      "name": "Data",
      "tagType": "Folder",
      "tags": [
        {
          "opcItemPath": {
            "bindType": "parameter",
            "binding": "nsu\u003dTOP Server;s\u003d{device}.Number_Of_Slots@short"
          },
          "value": {
            "bindType": "parameter",
            "binding": "{numberOfSlots}"
          },
          "valueSource": "memory",
          "eventScripts": [
            {
              "eventid": "valueChanged",
              "script": "\tdef updateEnable(startSlot, endSlot, doEnable):\n\t\tfor x in range(startSlot, endSlot):\n\t\t\tbase_path\u003d\u0027/\u0027.join(tagPath.split(\u0027/\u0027)[:-2])\n\t\t\tbase_list\u003d[\n\t\t\tbase_path + \"/data/Sts_Slot\" + str(x) + \".Enabled\"\n\t\t\t]\n\t\t\tresponse\u003dsystem.tag.writeAsync(base_list,[doEnable])\t\n\t\t\t\n\tif initialChange:\n\t\t updateEnable(0,currentValue.value,True)\t\n\t\t \n\telif previousValue.value \u003c currentValue.value:\n\t\t updateEnable(previousValue.value,currentValue.value,True)\t\n\t\t \n\telif initialChange or previousValue.value \u003e currentValue.value:\n\t\t updateEnable(currentValue.value,previousValue.value,False)\t"
            }
          ],
          "dataType": "Int4",
          "name": "Slot_Count",
          "tagType": "AtomicTag",
          "opcServer": "TOP Server/UA@QFCASH3D2VWIOA3.dcim.qts"
        },
        {
          "opcItemPath": {
            "bindType": "parameter",
            "binding": "nsu\u003dTOP Server;s\u003d{parent}_{suffix}.{plcName}.{Rack}_TCYCCUR"
          },
          "opcServer": {
            "bindType": "parameter",
            "binding": "{opcServer}"
          },
          "valueSource": "opc",
          "dataType": "Boolean",
          "name": "Current_Cycle_Time",
          "enabled": true,
          "tagType": "AtomicTag"
        },
        {
          "opcItemPath": {
            "bindType": "parameter",
